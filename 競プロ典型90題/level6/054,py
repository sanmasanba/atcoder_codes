#main
def main():
    # intput
    N, M = map(int, input().split())
    G = [[] for _ in range(N+M)]
    for m in range(M):
        K = int(input())
        # 各共著を超頂点として、距離を維持しながら
        # 辺の数をsum(K)辺まで減らす
        for v in list(map(lambda x:int(x)-1, input().split())):
            G[v].append(N+m)
            G[N+m].append(v)
    
    # 幅優先探索で決定していく
    q = deque([0])
    dist = [-2] * (N+M)
    dist[0] = 0
    while q:
        v = q.popleft()
        for u in G[v]:
            if dist[u] == -2:
                dist[u] = dist[v] + 1
                q.append(u)
    
    for d in dist[:N]: print(d//2)

if __name__ == '__main__':
    main()